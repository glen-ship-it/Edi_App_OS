{
  "manifest_version": 3,
  "name": "Eidetic — AI Memory State Manager",
  "description": "Photographic memory for every AI you use. Sync your context across Claude, Gemini, ChatGPT, Perplexity, and Grok.",
  "version": "0.1.0",
  "action": {
    "default_popup": "index.html"
  },
  "icons": {
    "16": "public/icons/icon-16.png",
    "48": "public/icons/icon-48.png",
    "128": "public/icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://www.perplexity.ai/*",
    "https://grok.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["src/content-scripts/claude.ts"]
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["src/content-scripts/gemini.ts"]
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["src/content-scripts/chatgpt.ts"]
    },
    {
      "matches": ["https://www.perplexity.ai/*"],
      "js": ["src/content-scripts/perplexity.ts"]
    },
    {
      "matches": ["https://grok.com/*"],
      "js": ["src/content-scripts/grok.ts"]
    }
  ]
}
